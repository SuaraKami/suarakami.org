---
import { getCollection, getEntry } from 'astro:content'
import BreadcrumbToolbar from '@/components/breadcrumb-toolbar.astro'
import ReadPanels from '@/components/read-panels.astro'
import Layout from '@/layouts/layout.astro'

export function getStaticPaths() {
  return getCollection('docs').then((docs) =>
    docs.map((doc) => ({
      params: { id: doc.id },
      props: { doc, id: doc.id },
    })),
  )
}

const { doc, id } = Astro.props;
const glossary = await getCollection('glossary')
---

<Layout title={doc.data.title} slug={id}>
  <BreadcrumbToolbar title={doc.data.title} slug={id} />
  <div class="flex-1 overflow-y-auto px-4 py-6 md:px-20 md:py-10">
    <div class="max-w-4xl space-y-6 pb-20">
      <ReadPanels entry={doc} glossary={glossary} />
    </div>
  </div>
</Layout>
