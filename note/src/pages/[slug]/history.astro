---
  import { getCollection, getEntry } from "astro:content";
  import BreadcrumbToolbar from "@/components/breadcrumb-toolbar.astro";
  import HistoryPanels from "@/components/history-panels.astro";
  import Layout from "@/layouts/layout.astro";

  export function getStaticPaths() {
    return getCollection("docs").then((entries) =>
      entries.map((entry) => ({
        params: { slug: entry.slug },
      }))
    );
  }

  const { slug } = Astro.params;
  const entry = await getEntry("docs", slug);

  if (!entry) {
    throw new Error(`Entry with slug "${slug}" not found.`);
  }
---
<Layout title={entry.data.title} slug={slug}>
  <BreadcrumbToolbar title={entry.data.title} slug={slug} viewMode="history"/>
  <div class="flex-1 overflow-y-auto px-4 py-6 md:px-20 md:py-10">
    <div class="mx-auto max-w-4xl space-y-6 pb-20">
      <HistoryPanels history={entry.data.history}/>
    </div>
  </div>
</Layout>
