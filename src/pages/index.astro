---
import Layout from '@/layouts/layout.astro'
import { Icon } from 'astro-icon/components'
import { getCollection } from 'astro:content'

const docs = (await getCollection('docs')).sort((a, b) => a.slug.localeCompare(b.slug))
const dateFormatter = new Intl.DateTimeFormat('id-ID', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'Europe/Berlin',
})
---

<Layout title="Dokumen Internal SuaraKami">
  <div class="flex-1 overflow-y-auto px-4 md:px-20 py-6 md:py-10">
    <div class="space-y-8">
      <header class="space-y-3">
        <div class="flex items-center gap-3 text-foreground">
          <Icon name="hugeicons:folder-01" class="size-6 text-primary" />
          <h1 class="text-2xl font-semibold">Dokumen Internal SuaraKami</h1>
        </div>
        <p class="text-sm text-foreground-muted md:text-base">
          Dokumen ini adalah kompas moral dan intelektual SuaraKami. Berangkat dari kegelisahan sederhana di Aachen,
          naskah ini merangkum perjalanan transformasi kami, dari ambisi teknis menjadi gerakan kultural. Di dalamnya,
          kami menuangkan sejarah, landasan filosofis, hingga metode kerja horizontal yang kami hidupi sehari-hari.
        </p>
      </header>

      <section class="space-y-4">
        <div class="flex items-center text-xs uppercase tracking-widest text-foreground-subtle">
          <span>Daftar Dokumen</span>
          <span class="ml-auto text-xs tracking-widest">{docs.length} FILE</span>
        </div>
        <div class="grid gap-4">
          {
            docs.map((doc) => (
              <a
                class="group space-y-3 rounded-lg border border-border bg-panel/70 p-4 transition hover:border-primary/60 hover:bg-surface"
                href={`/${doc.slug}`}
              >
                <div class="flex items-center gap-2 text-foreground">
                  <Icon name="hugeicons:file-02" class="size-4 text-primary" />
                  <span class="font-semibold">{doc.data.title}</span>
                </div>
                {doc.data.summary && <p class="mt-2 text-sm text-foreground-muted">{doc.data.summary}</p>}
                <div class="flex items-center justify-between text-xs text-foreground-muted">
                  <span class="flex items-center gap-1">
                    <Icon name="hugeicons:clock-03" class="size-4" />
                    Terakhir diperbarui
                    {dateFormatter.format(doc.data.updated)}
                  </span>
                  <span class="text-primary group-hover:underline">Buka &rarr;</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</Layout>
