---
  import type { CollectionEntry } from "astro:content";
  import type { LanguageKeys } from "@/i18n";
  import Container from "../vue/Container.vue";

  interface Props {
    page: CollectionEntry<"index">;
    lang: LanguageKeys;
  }
  const { page } = Astro.props;
---
<section id="hero" class="bg-background relative overflow-hidden">
  <Container
    grid
    class="gap-y-16 pt-32 pb-36 md:pt-40 md:pb-48 lg:pt-48 lg:pb-64"
  >
    <div class="col-span-12 lg:col-span-10 xl:col-span-9 z-10">
      <h1
        class={`
          text-[3.5rem] leading-[0.95] font-black tracking-tighter text-balance
          sm:text-7xl
          md:text-[6rem]
          lg:text-[7.5rem]
          xl:text-[9rem]
          animate-in fade-in slide-in-from-bottom-8 duration-1000 ease-out-expo
        `}
      >
        {page.data.hero.title}
      </h1>
    </div>
    <div
      class="col-span-12 lg:col-span-5 lg:col-start-8 flex flex-col items-start z-10
             animate-in fade-in slide-in-from-bottom-4 duration-1000 delay-300 ease-out-expo fill-mode-both"
    >
      <p
        class="mb-10 text-xl leading-relaxed opacity-80 md:text-2xl font-medium tracking-tight text-balance"
      >
        {page.data.hero.description}
      </p>

      <a
        href={page.data.hero.link.to}
        target={page.data.hero.link.target}
        rel="noopener noreferrer"
        class={`
          inline-flex items-center justify-center
          border border-foreground bg-foreground px-8 py-5
          text-sm font-semibold tracking-widest text-background uppercase
          transition-all duration-300 ease-out
          hover:bg-background hover:text-foreground
        `}
      >
        {page.data.hero.link.label}
      </a>
    </div>
  </Container>
  <div class="absolute inset-0 pointer-events-none opacity-5">
    <div
      class="w-px h-full bg-foreground absolute left-6 md:left-12 lg:left-20 xl:left-32"
    ></div>
    <div
      class="w-px h-full bg-foreground absolute left-1/2 -translate-x-1/2"
    ></div>
    <div
      class="w-px h-full bg-foreground absolute right-6 md:right-12 lg:right-20 xl:right-32"
    ></div>
  </div>
</section>
