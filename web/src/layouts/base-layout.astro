---
import BaseHead from '@/components/base-head.astro'
import Footer from '@/components/footer.astro'
import Header from '@/components/header.astro'
import LanguageRedirect from '@/components/language-redirect.astro'
import CustomCursor from '@/components/vue/custom-cursor.vue'
import SmoothScroll from '@/components/vue/smooth-scroll.vue'
import type { LanguageKeys } from '@/i18n'

interface Props {
  title: string
  description: string
  lang?: LanguageKeys
  includeLanguageRedirect?: boolean
}

const { title, description, lang = 'en', includeLanguageRedirect = false } = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    {includeLanguageRedirect && <LanguageRedirect />}
    <SmoothScroll client:load />
    <CustomCursor client:only="vue" />
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
